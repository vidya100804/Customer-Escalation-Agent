# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# OpenRouter (OpenAI-compatible fallback)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=google/gemini-2.5-pro
LLM_MAX_TOKENS=700

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Real production evidence adapters (optional)
# Leave any of these unset to fall back to mock data for that source.
# Templates support:
#   {email}
#   {email_urlencoded}
#   {ticket_id}
#   {priority}
#   {reporter_name}
#   {issue_summary}

USER_API_URL_TEMPLATE=https://internal.example.com/users?email={email_urlencoded}
USER_API_METHOD=GET
USER_API_HEADERS_JSON={"X-Internal-Service":"customer-escalation-agent"}
USER_API_TOKEN=replace-me-user-api-token

LOGS_API_URL_TEMPLATE=https://logs.example.com/search?customer_email={email_urlencoded}
LOGS_API_METHOD=GET
LOGS_API_HEADERS_JSON={"X-Internal-Service":"customer-escalation-agent"}
LOGS_API_TOKEN=replace-me-logs-api-token

TICKETS_API_URL_TEMPLATE=https://support.example.com/tickets?requester_email={email_urlencoded}
TICKETS_API_METHOD=GET
TICKETS_API_HEADERS_JSON={"X-Internal-Service":"customer-escalation-agent"}
TICKETS_API_TOKEN=replace-me-tickets-api-token

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_PORT=3000
